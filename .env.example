# ---- LinkTranscript environment variables ----
# Copy to .env.local for local dev. In production, set these in your host (Vercel).
# Nothing here is required for the core v1 transcript utility to work.

# Public site URL — used for canonical tags, sitemap, and OpenGraph.
# Local dev: http://localhost:3000  ·  Production: https://linktranscript.com
NEXT_PUBLIC_SITE_URL=https://linktranscript.com

# ---- Feature flags ----
# Personal media-download functionality. Keep false; not surfaced in the public UI.
ENABLE_PERSONAL_DOWNLOADS=false
# Short-lived in-memory transcript cache.
ENABLE_TRANSCRIPT_CACHE=true

# ---- Google AdSense (leave blank until you have an approved publisher ID) ----
# When empty, NO ad code loads and NO placeholder boxes ship to production.
# Example value: ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# ---- Optional: YouTube proxy ----
# Route YouTube requests through a proxy (helps when cloud/datacenter IPs are blocked).
# Example: http://user:pass@host:port
YOUTUBE_PROXY_URL=

# =====================================================================
# BACKLOG (NOT used in v1) — AI "Transform Transcript" features.
# Leave these unset for v1. The app runs fully without any AI API key.
# To enable later: set ENABLE_AI_TRANSFORMS=true and provide an API key.
# =====================================================================
ENABLE_AI_TRANSFORMS=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
