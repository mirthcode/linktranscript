# ---- LinkTranscript environment variables ----
# Copy to .env.local for local dev. In production, set these in your host (Vercel).
# NONE are required for the core transcript tool to work locally.

# ===== Core / SEO =====
# Canonical production URL — used for canonical tags, sitemap, OpenGraph.
NEXT_PUBLIC_SITE_URL=https://linktranscript.com
# Google Analytics 4 Measurement ID (public). Empty = no analytics scripts.
NEXT_PUBLIC_GA_ID=

# ===== Transcript provider (REQUIRED in production) =====
# YouTube blocks datacenter IPs, so direct extraction fails on Vercel.
# TranscriptAPI (https://transcriptapi.com) fetches via residential proxies.
# Empty locally = direct extraction fallback.
TRANSCRIPTAPI_KEY=
TRANSCRIPTAPI_BASE_URL=
# Optional: route direct YouTube requests through your own proxy instead.
YOUTUBE_PROXY_URL=

# ===== Caching & rate limiting (cost protection) =====
ENABLE_TRANSCRIPT_CACHE=true
TRANSCRIPT_CACHE_TTL_DAYS=30
TRANSCRIPT_IP_HOURLY_LIMIT=30
TRANSCRIPT_IP_DAILY_LIMIT=150
TRANSCRIPT_GLOBAL_DAILY_LIMIT=5000

# ===== Cloudflare Turnstile (optional bot challenge) =====
# Off by default so normal users never see a challenge. When enabled, the
# transcript/summary routes require a valid token.
ENABLE_CLOUDFLARE_TURNSTILE=false
CLOUDFLARE_TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=

# ===== Ads (leave blank until AdSense-approved) =====
# When empty, no ad code loads and no placeholder boxes ship to production.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# ===== Personal downloads (keep false; not surfaced in UI) =====
ENABLE_PERSONAL_DOWNLOADS=false

# =====================================================================
# OPTIONAL SUMMARIES (Phase 2 — disabled by default; not built yet in v1)
# The Summary feature is server-side only; AI keys are NEVER exposed to the
# browser. When ENABLE_SUMMARIES=false the Summary button is hidden.
# =====================================================================
ENABLE_SUMMARIES=false
AI_PROVIDER=gemini
GEMINI_API_KEY=
OPENROUTER_API_KEY=
CLOUDFLARE_AI_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
GROQ_API_KEY=
OPENAI_API_KEY=
SUMMARY_IP_DAILY_LIMIT=3
SUMMARY_IP_HOURLY_LIMIT=3
SUMMARY_GLOBAL_DAILY_LIMIT=500
SUMMARY_MAX_TRANSCRIPT_CHARS=48000
SUMMARY_CACHE_TTL_DAYS=30

# =====================================================================
# SEO WATCHDOG (Phase 2 — optional; weekly Search Console report)
# Only used if configured. Service-account creds for the GSC API.
# =====================================================================
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://linktranscript.com/
